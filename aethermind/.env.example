# Supabase — get from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only used in Edge Functions (server-side) — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — stored as Edge Function secret in Supabase dashboard
ANTHROPIC_API_KEY=sk-ant-...

# RazorPay — https://dashboard.razorpay.com/app/keys
# EXPO_PUBLIC_ prefix = safe to bundle in client
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Internal cron job auth (generate a random string)
CRON_SECRET=your-cron-secret
